{
	"name": "write-nostr",
	"version": "0.2.3",
	"private": false,
	"description": "Browser-based long-form writing app for the Nostr protocol — NIP-23 editor, feed reader, and publishing tool",
	"license": "MIT",
	"author": "lostcause <lostcause@3nostr.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/imattau/write_nostr.git"
	},
	"bugs": {
		"url": "https://github.com/imattau/write_nostr/issues"
	},
	"homepage": "https://github.com/imattau/write_nostr#readme",
	"keywords": [
		"nostr",
		"nip-23",
		"long-form",
		"writing",
		"markdown",
		"editor",
		"svelte",
		"sveltekit",
		"pwa"
	],
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"files": [
		"build/",
		"scripts/",
		"static/",
		"svelte.config.js",
		"tsconfig.json",
		"vite.config.ts",
		"vitest.config.ts",
		"README.md",
		"LICENSE"
	],
	"bin": {
		"write-nostr": "scripts/serve.mjs"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "bash scripts/deploy-remote.sh",
		"prepare": "svelte-kit sync || echo ''",
		"prepublishOnly": "npm run build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"tauri": "tauri",
		"tauri:dev": "node scripts/dev-tauri.mjs",
		"tauri:build": "tauri build"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tauri-apps/cli": "^2.11.4",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@0xx0lostcause0xx0/disgus": "github:imattau/disgus",
		"@0xx0lostcause0xx0/polypack": "^2.3.0",
		"@noble/hashes": "^1.8.0",
		"@scure/base": "^1.2.5",
		"@sveltejs/adapter-static": "^3.0.10",
		"@tauri-apps/api": "^2.11.1",
		"marked": "^18.0.5",
		"nostr-passkey": "^0.3.0",
		"nostr-tools": "^2.23.9"
	}
}
