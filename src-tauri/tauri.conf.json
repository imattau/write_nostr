{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "write_nostr",
  "version": "0.1.5",
  "identifier": "com.writenostr.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "write_nostr",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' wss://*; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "A minimalist writing space on Nostr",
    "longDescription": "Compose, publish, and manage NIP-23 long-form content on the Nostr protocol.",
    "homepage": "https://github.com/imattau/write_nostr",
    "license": "MIT",
    "publisher": "write_nostr",
    "category": "Utility",
    "linux": {
      "deb": {
        "depends": ["librsvg2-2"]
      }
    }
  }
}
